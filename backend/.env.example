# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Either supply DATABASE_URL, or the discrete PG* values below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vetconnect
PGSSL=false               # set true for Supabase / Railway / Render

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=1h
BCRYPT_ROUNDS=12

# ── Email (Nodemailer) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="VetConnect Ibafo <no-reply@vetconnect.ng>"

# ── Geo / Maps ──────────────────────────────────────────────────────────────
# Leaflet/OSM needs no key. Set this only if you switch to Google Maps.
GOOGLE_MAPS_API_KEY=

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
